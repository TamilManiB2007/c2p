# Application
APP_NAME="C2P Platform API"
APP_VERSION="0.1.0"
DEBUG=True

# API
API_V1_PREFIX="/api/v1"

# Database (PostgreSQL for production, SQLite used in tests)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/c2p_platform"

# Security
SECRET_KEY="c2p-dev-secret-key-change-in-production-must-be-32-chars-min"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=43200
BCRYPT_ROUNDS=12

# File Storage
UPLOAD_DIR="uploads/contracts"
MAX_FILE_SIZE_MB=20
