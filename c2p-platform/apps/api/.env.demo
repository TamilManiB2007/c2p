# Demo environment - uses SQLite so no PostgreSQL needed
APP_NAME="C2P Platform API"
APP_VERSION="0.1.0"
DEBUG=True
API_V1_PREFIX="/api/v1"

# SQLite for local demo (replace with PostgreSQL URL in production)
DATABASE_URL="sqlite:///./demo_c2p.db"

# Security
SECRET_KEY="c2p-demo-secret-key-32-chars-minimum-ok"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=43200
BCRYPT_ROUNDS=4

# File Storage
UPLOAD_DIR="uploads/contracts"
MAX_FILE_SIZE_MB=20
